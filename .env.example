# Flask backend configuration — copy to `.env` and adjust for your setup.

# Flask environment: development | production
FLASK_ENV=development
FLASK_DEBUG=1

# Port the Flask API server listens on
FLASK_PORT=5000

# Comma-separated list of origins allowed to call the API (CORS).
# Include the address(es) the Svelte dev server / tablet are served from.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
