# Frontend configuration — copy to `.env.development.local` (or `.env.local`).
#
# Base URL of the Flask backend API. Point this at wherever app.py is running.
# On a Raspberry Pi deployment this is typically the Pi's LAN address, e.g.
#   VITE_API_URL=http://192.168.1.50:5000
# For local development against a backend on the same machine:
VITE_API_URL=http://localhost:5000
